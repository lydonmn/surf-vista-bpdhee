
{
  "expo": {
    "name": "SurfVista",
    "slug": "SurfVista",
    "version": "13.0.5",
    "orientation": "portrait",
    "primaryColor": "#1E90FF",
    "description": "Premium surf reports and forecasts for Folly Beach, South Carolina. Get exclusive 6K drone footage, real-time conditions, and AI-powered surf predictions.",
    "icon": "./assets/images/SurfVista Logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/SurfVista Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E90FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "Therealfollysurfreport.SurfVista",
      "buildNumber": "34",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "SurfVista needs access to your photo library to upload high-resolution surf report videos for subscribers.",
        "NSCameraUsageDescription": "SurfVista needs access to your camera to capture surf condition videos.",
        "NSMicrophoneUsageDescription": "SurfVista needs access to your microphone to record audio with surf report videos.",
        "NSPhotoLibraryAddUsageDescription": "SurfVista needs permission to save videos to your photo library.",
        "UIBackgroundModes": [
          "remote-notification",
          "fetch",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "Therealfollysurfreport.SurfVista.refresh",
          "Therealfollysurfreport.SurfVista.processing",
          "Therealfollysurfreport.SurfVista.video-download"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      },
      "associatedDomains": [
        "applinks:ucbilksfpnmltrkwvzft.supabase.co"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/SurfVista Logo.png",
        "backgroundColor": "#1E90FF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.therealfollysurfreport.SurfVista",
      "versionCode": 34,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_VIDEO",
        "CAMERA",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ucbilksfpnmltrkwvzft.supabase.co",
              "pathPrefix": "/auth/v1/verify"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/SurfVista Logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow SurfVista to access your photos to upload 6K drone videos.",
          "savePhotosPermission": "Allow SurfVista to save videos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/SurfVista Logo.png",
          "color": "#1E90FF"
        }
      ]
    ],
    "scheme": "surfvista",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e1ee166c-212b-4eca-a1d7-44183b7be073"
      }
    }
  }
}
