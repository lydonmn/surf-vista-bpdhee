{
  "expo": {
    "name": "SurfVista",
    "slug": "surfvista",
    "version": "13.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/d1b0f78f-fe17-49d7-a60f-6db90ccdc8ba.jpeg",
    "scheme": "surfvista",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/d1b0f78f-fe17-49d7-a60f-6db90ccdc8ba.jpeg",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "32",
      "bundleIdentifier": "com.therealfollysurfreport.surfvista",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to upload surf report videos.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload surf report videos.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to record audio for surf report videos.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.Therealfollysurfreport.SurfVista.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/d1b0f78f-fe17-49d7-a60f-6db90ccdc8ba.jpeg",
        "backgroundColor": "#000000"
      },
      "package": "com.lukestageberg.SurfVista",
      "versionCode": 32
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/SurfVista Logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/d1b0f78f-fe17-49d7-a60f-6db90ccdc8ba.jpeg",
          "color": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {},
      "oneSignalAppId": "b991c245-3c87-4a1b-9676-b23323e73f07"
    }
  }
}