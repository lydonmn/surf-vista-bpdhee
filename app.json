{
  "expo": {
    "name": "SurfVista",
    "slug": "surfvista",
    "version": "13.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/IMG_9054.png",
    "scheme": "surfvista",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/IMG_9054.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "35",
      "bundleIdentifier": "Therealfollysurfreport.SurfVista",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to upload surf report videos.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload surf report videos.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to record audio for surf report videos.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/IMG_9054.png",
        "backgroundColor": "#000000"
      },
      "package": "com.lukestageberg.SurfVista",
      "versionCode": 35,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/SurfVista Logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/IMG_9054.png",
          "color": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {},
      "oneSignalAppId": "b991c245-3c87-4a1b-9676-b23323e73f07",
      "revenueCatApiKeyIos": "appl_uyUNhkTURhBCqiVsRaBqBYbhIda",
      "revenueCatApiKeyAndroid": "goog_HpaeitYCWGXDSXGokGGUQzHxGiA",
      "revenueCatEntitlementId": "pro",
      "nativelyProjectId": "e1ee166c-212b-4eca-a1d7-44183b7be073"
    }
  }
}