{
  "expo": {
    "name": "SurfVista",
    "slug": "surfvista",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SurfVista Logo.png",
    "scheme": "surfvista",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lukestageberg.SurfVista",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to upload surf report videos.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload surf report videos.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to record audio for surf report videos."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/SurfVista Logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lukestageberg.SurfVista"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/SurfVista Logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/SurfVista Logo.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {}
    }
  }
}
